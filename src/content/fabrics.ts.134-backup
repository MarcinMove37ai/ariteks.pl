// src/content/fabrics.ts
// JEDNO ZRODLO PRAWDY dla katalogu tkanin — 134 produkty w 34 kategoriach.
// WYGENEROWANE z /ariteks/fabrics/data/all-fabrics-manifest.json — nie edytowac
// recznie pol produktow; poprawki nazw/slugow kategorii sa OK.
// Struktura wzorowana na applications.ts (Record<Locale> dla tresci PL/EN,
// stringi neutralne dla danych technicznych).
//
// Warstwy podzialu:
//  - kategoria (categoryId) — 34 oryginalne grupy z ariteks.net,
//  - rodzina (family)      — linia handlowa z nazwy (ArNeo, ArWoWear...),
//  - wlasciwosci (properties) — filtry: hi-vis, fr, antistatic, ...
// Parametry typu odpornosc na 100 pran sa WLASCIWOSCIA (wash-100),
// nie kategoria. Powiazania z branzami (applications) dojda w osobnym kroku.

import type { Locale } from '@/i18n/routing';

/** Wlasciwosc filtrowalna tkaniny */
export type FabricProperty =
  | 'hi-vis'
  | 'fr'
  | 'inherent-fr'
  | 'antistatic'
  | 'arc'
  | 'molten-metal'
  | 'emi'
  | 'chemical'
  | 'waterproof'
  | 'water-repellent'
  | 'breathable'
  | 'stretch'
  | 'antibacterial'
  | 'antiviral'
  | 'cut-resistant'
  | 'uv-protection'
  | 'wash-100';

/** Etykiety wlasciwosci do chipow filtrow */
