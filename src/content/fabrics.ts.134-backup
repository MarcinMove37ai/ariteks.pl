/** Podlinia (rodzina) produktowa — 1 rodzina = 1 podstrona = 1 karta PDF.
 *  Hero i sciezka PDF: src/content/families-assets.json (KROK 3). */
export type FabricFamilyDef = {
  /** stem — slug neutralny jezykowo (aramid-vis-knit) */
  slug: string;
  /** nazwa handlowa linii (wspolna PL/EN) */
  name: string;
  descriptor: Record<Locale, string>;
};

