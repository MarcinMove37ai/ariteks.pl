/** Produkt katalogu */
export type FabricDef = {
  /** Unikalny slug z manifestu (neutralny jezykowo) */
  slug: string;
  name: string;
  /** Linia handlowa: ArNeo, ArWoWear, ArDura, Aramid... */
  family: string;
/** Kanoniczny slug podstrony rodziny, np. arneo */
  subFamily: string;
  categoryId: string;
  weight: string;
  /** Gramatura liczbowo do filtra zakresu (null gdy brak) */
  weightGsm: number | null;
  composition: string;
  weave: string;
  /** Rodzina splotu do filtra */
  weaveType: FabricWeaveType;
  /** Wlokna w skladzie do filtra */
  fibers: FabricFiber[];
  titleDescriptor: string;
  specLine: string;
  properties: FabricProperty[];
  /** Etykiety norm/ikon funkcji (EN 20471, Oeko Tex...) */
  norms: string[];
  heroImage: string | null;
  dataSheets: string[];
  certificates: string[];
  colorsCount: number;
  parametersCount: number;
  /** fabric-complete-record.json — pelne dane do strony produktu */
  recordUrl: string;
};

