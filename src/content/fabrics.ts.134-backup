// ============================= HELPERY =============================

export function getFabricBySlug(slug: string): FabricDef | undefined {
  return FABRICS.find((f) => f.slug === slug);
}

export function getFabricSlugs(): string[] {
  return FABRICS.map((f) => f.slug);
}

export function getCategoryBySlug(
  locale: Locale,
  slug: string
): FabricCategoryDef | undefined {
  return FABRIC_CATEGORIES.find((c) => c.slug[locale] === slug);
}

export function getCategoryById(id: string): FabricCategoryDef | undefined {
  return FABRIC_CATEGORIES.find((c) => c.id === id);
}

export function getCategorySlugs(locale: Locale): string[] {
  return FABRIC_CATEGORIES.map((c) => c.slug[locale]);
}

export function getFabricsByCategory(categoryId: string): FabricDef[] {
  return FABRICS.filter((f) => f.categoryId === categoryId);
}

export function getFamilyBySlug(slug: string): FabricFamilyDef | undefined {
  return FABRIC_FAMILIES.find((f) => f.slug === slug);
}

export function getFabricsBySubFamily(
  subFamily: string
): FabricDef[] {
  return FABRICS.filter((fabric) => fabric.subFamily === subFamily);
}

export function getFamilySlugs(): string[] {
  return FABRIC_FAMILIES.map((f) => f.slug);
}

export function getFabricsByFamily(family: string): FabricDef[] {
  return FABRICS.filter((f) => f.family === family);
}

/** Rodziny posortowane malejaco po liczbie wariantow */
export function getFabricFamilies(): { family: string; count: number }[] {
  const m = new Map<string, number>();
  for (const f of FABRICS) m.set(f.family, (m.get(f.family) ?? 0) + 1);
  return [...m.entries()]
    .map(([family, count]) => ({ family, count }))
    .sort((a, b) => b.count - a.count || a.family.localeCompare(b.family));
}