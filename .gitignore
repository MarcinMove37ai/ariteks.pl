# ==========================================================
# .gitignore — Ariteks / Next.js
# ==========================================================

# ----------------------------------------------------------
# Zmienne środowiskowe i sekrety
# ----------------------------------------------------------
# .env.example pozostaje śledzony.
.env
.env*.local

# ----------------------------------------------------------
# Next.js
# ----------------------------------------------------------
/.next/
/out/
/build/

# ----------------------------------------------------------
# Zależności
# ----------------------------------------------------------
/node_modules/
/.pnp/
.pnp.js
.yarn/install-state.gz

# ----------------------------------------------------------
# TypeScript
# ----------------------------------------------------------
*.tsbuildinfo

# next-env.d.ts powinien być przechowywany w repozytorium,
# dlatego nie jest ignorowany.

# ----------------------------------------------------------
# Logi
# ----------------------------------------------------------
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ----------------------------------------------------------
# Testy i coverage
# ----------------------------------------------------------
/coverage/

# ----------------------------------------------------------
# Vercel
# ----------------------------------------------------------
.vercel/

# ----------------------------------------------------------
# System i edytory
# ----------------------------------------------------------
.DS_Store
Thumbs.db
*.pem

.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

# Dodatkowe ustawienia IDE znalezione w assetach
/public/ariteks/.idea/

# ----------------------------------------------------------
# Python — środowiska i cache
# ----------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo

.venv/
venv/
env/

scripts/certyficates/.venv/
scripts/certificates/.venv/

# ----------------------------------------------------------
# Lokalne skrypty pomocnicze w głównym katalogu
# ----------------------------------------------------------
# Dotyczy tylko plików Python bezpośrednio w katalogu projektu.
# Nie ignoruje skryptów znajdujących się w /scripts.
/*.py

# ----------------------------------------------------------
# Lokalne raporty i dane robocze w głównym katalogu
# ----------------------------------------------------------
/*_report.md
/scan_report.md
/rowdocs_text_report.md
/family_mapping.json

/_backup_src.zip
/_hero_review/
/_i18n_cache/

# ----------------------------------------------------------
# Surowe dane scrapera
# ----------------------------------------------------------
/_scraped/
next-env.d.ts
*.bak-*
/public/ariteks/fabrics/*.py
