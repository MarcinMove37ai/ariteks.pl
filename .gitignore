# ==========================================================
# .gitignore — Ariteks (Next.js) + skrypty pomocnicze
# ==========================================================

# --- KLUCZOWE: zmienne srodowiskowe (klucz Web3Forms!) ---
# NIGDY nie commituj plikow .env*.local — zawieraja sekrety.
.env*.local
.env

# --- Next.js ---
/.next/
/out/
next-env.d.ts

# --- Zaleznosci ---
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# --- Produkcja / build ---
/build

# --- Debug / logi ---
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# --- Systemowe / edytor ---
.DS_Store
*.pem
Thumbs.db

# --- Vercel / typowe ---
.vercel

# --- TypeScript ---
*.tsbuildinfo

# --- Puste katalogi po usunietych trasach scaffoldu ---
# Nawiasy [locale] to w .gitignore znak specjalny (klasa znakow),
# wiec MUSZA byc wyescapowane ukosnikiem: \[locale\]
src/app/\[locale\]/contact/
src/app/\[locale\]/fabrics/
src/app/\[locale\]/partners/
src/app/\[locale\]/technologies/

# ==========================================================
# Reguly wlasne projektu
# ==========================================================

# Local Python environments
scripts/certyficates/.venv/

# Raw scraped data
_scraped/